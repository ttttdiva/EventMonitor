# テスト用環境変数設定例
# 実際のテスト時は .env.test にコピーして使用

# テストモード識別
TESTING=1

# Twitter API認証（テスト用ダミー値）
TWITTER_AUTH_TOKEN=test_token_for_testing
TWITTER_CT0=test_ct0_for_testing

# Discord通知（テスト用URL）
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/test_webhook_url

# LLM API（テスト用キー）
OPENAI_API_KEY=test_openai_key
GOOGLE_API_KEY=test_google_key

# データベース
DB_PASSWORD=test_db_password

# HuggingFace
HUGGINGFACE_TOKEN=test_hf_token

# Hydrus（テスト時は無効）
HYDRUS_API_URL=http://localhost:45869
HYDRUS_ACCESS_KEY=test_hydrus_key